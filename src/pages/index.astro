---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Testimonial from '../components/Testimonial.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import { getHomepage, getServices, getStrapiImageUrl } from '../lib/strapi';

const homepage = await getHomepage();
const services = await getServices();
---

<Layout title={homepage?.heroTitle ?? 'Airfolio — Portfolio'}>
  <Navbar currentPath={Astro.url.pathname} />
  <main>
    <Hero
      name={homepage?.heroGreeting ?? undefined}
      title={homepage?.heroTitle ?? undefined}
      subtitle={homepage?.heroSubtitle ?? undefined}
      heroImage={homepage?.heroImage
        ? getStrapiImageUrl(homepage.heroImage, 'large')
        : undefined}
      heroImageAlt={homepage?.heroGreeting ?? undefined}
      ctaPrimary={homepage?.heroPrimaryLabel
        ? { label: homepage.heroPrimaryLabel, href: '/contact' }
        : undefined}
      ctaSecondary={homepage?.heroSecondaryLabel
        ? { label: homepage.heroSecondaryLabel, href: '/portfolio' }
        : undefined}
    />
    <Services
      label={homepage?.servicesLabel ?? undefined}
      title={homepage?.servicesTitle ?? undefined}
      description={homepage?.servicesDescription ?? undefined}
      services={services.length > 0 ? services : undefined}
    />
    
    <About
      label={homepage?.aboutLabel ?? undefined}
      title={homepage?.aboutTitle ?? undefined}
      description={homepage?.aboutDescription ?? undefined}
      image={homepage?.aboutImage ? getStrapiImageUrl(homepage.aboutImage, 'large') : undefined}
      imageAlt={homepage?.aboutAltImage ?? undefined}
    />
    <Experience />
    <Projects />
    <Testimonial />
    <FAQ />
  </main>
  <Footer />
</Layout>