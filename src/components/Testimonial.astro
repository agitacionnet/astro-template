---
// src/components/Testimonial.astro

export interface TestimonialItem {
  quote: string;
  name: string;
  role: string;
  avatar: string;
  companyLogo?: string;
  companyName?: string;
}

export interface Props {
  testimonials?: TestimonialItem[];
}

const {
  testimonials = [
    {
      quote:       "Airfolio has been instrumental in showcasing my design portfolio. Their UIUX design services are top-notch and their Webflow development has taken my website to the next level.",
      name:        'John Doe',
      role:        'Graphic Designer, ABC Company',
      avatar:      '/images/testimonial-avatar.jpg',
      companyLogo: '/icons/webflow-white.svg',
      companyName: 'Webflow',
    },
  ],
} = Astro.props;
---

<section class="testimonial" aria-label="Testimonials">
  <div class="testimonial__inner">

    <div class="testimonial__slider" id="testimonial-slider">
      {testimonials.map((item, i) => (
        <div
          class:list={['testimonial__slide', { 'is-active': i === 0 }]}
          aria-hidden={i !== 0}
          data-index={i}
        >
          <!-- Estrellas -->
          <div class="testimonial__stars" aria-label="5 out of 5 stars">
            {Array(5).fill(null).map(() => (
              <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <!-- Cita -->
          <blockquote class="testimonial__quote">
            {item.quote}
          </blockquote>

          <!-- Autor -->
          <div class="testimonial__author">
            <img
              src={item.avatar}
              alt={`${item.name} avatar`}
              class="testimonial__avatar"
              width="56"
              height="56"
              loading="lazy"
            />
            <div class="testimonial__author-info">
              <p class="testimonial__name">{item.name}</p>
              <p class="testimonial__role">{item.role}</p>
            </div>
            {item.companyLogo && (
              <>
                <div class="testimonial__divider" aria-hidden="true"></div>
                <img
                  src={item.companyLogo}
                  alt={item.companyName ?? 'Company logo'}
                  class="testimonial__company-logo"
                  width="120"
                  height="48"
                  loading="lazy"
                />
              </>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Controles -->
    <div class="testimonial__controls">
      <button class="testimonial__btn testimonial__btn--prev" id="prev-btn" aria-label="Previous testimonial">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Dots -->
      <div class="testimonial__dots" role="tablist" aria-label="Testimonial navigation">
        {testimonials.map((_, i) => (
          <button
            class:list={['testimonial__dot', { 'is-active': i === 0 }]}
            data-index={i}
            role="tab"
            aria-selected={i === 0}
            aria-label={`Testimonial ${i + 1}`}
          ></button>
        ))}
      </div>

      <button class="testimonial__btn testimonial__btn--next" id="next-btn" aria-label="Next testimonial">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<style>
  .testimonial {
    width: 100%;
    background-color: var(--color-blue-13);
  }

  .testimonial__inner {
    max-width: var(--width-container);
    margin-inline: auto;
    padding-inline: var(--spacing-64);
    padding-block: var(--spacing-112);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-48);
  }

  /* ── Slider ────────────────────────────── */
  .testimonial__slider {
    position: relative;
    width: 100%;
    max-width: var(--width-text);
  }

  .testimonial__slide {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-32);
    text-align: center;
  }
  .testimonial__slide.is-active { display: flex; }

  /* ── Estrellas ─────────────────────────── */
  .testimonial__stars {
    display: flex;
    gap: 4px;
    color: var(--color-white);
  }

  /* ── Cita ──────────────────────────────── */
  .testimonial__quote {
    font-family: var(--font-sans);
    font-size: var(--font-size-lg);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.16px;
    color: var(--color-white);
    margin: 0;
  }

  /* ── Autor ─────────────────────────────── */
  .testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--spacing-20);
  }

  .testimonial__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial__author-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .testimonial__name {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-white);
    margin: 0;
  }

  .testimonial__role {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-white);
    margin: 0;
  }

  .testimonial__divider {
    width: 1px;
    height: 48px;
    background-color: rgba(255,255,255,0.4);
    flex-shrink: 0;
  }

  .testimonial__company-logo {
    height: 48px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  /* ── Controles ─────────────────────────── */
  .testimonial__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-24);
    width: 100%;
    max-width: var(--width-text);
  }

  .testimonial__btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s;
    flex-shrink: 0;
  }

  .testimonial__btn--prev {
    background-color: var(--color-white);
    color: var(--color-black);
  }
  .testimonial__btn--prev:hover { background-color: var(--color-blue-3); }

  .testimonial__btn--next {
    background-color: var(--color-blue-7);
    color: var(--color-white);
  }
  .testimonial__btn--next:hover { background-color: var(--color-blue-6); }

  .testimonial__dots {
    display: flex;
    align-items: center;
    gap: var(--spacing-8);
    flex: 1;
    justify-content: center;
  }

  .testimonial__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.4);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s, transform 0.2s;
  }
  .testimonial__dot.is-active {
    background-color: var(--color-white);
    transform: scale(1.3);
  }

  @media (max-width: 640px) {
    .testimonial__inner { padding-inline: var(--spacing-24); }
    .testimonial__quote { font-size: var(--font-size-base); }
    .testimonial__author { flex-wrap: wrap; justify-content: center; }
    .testimonial__divider { display: none; }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.testimonial__slide');
  const dots   = document.querySelectorAll<HTMLElement>('.testimonial__dot');
  let current  = 0;

  function goTo(index: number) {
    slides[current].classList.remove('is-active');
    slides[current].setAttribute('aria-hidden', 'true');
    dots[current].classList.remove('is-active');
    dots[current].setAttribute('aria-selected', 'false');

    current = (index + slides.length) % slides.length;

    slides[current].classList.add('is-active');
    slides[current].setAttribute('aria-hidden', 'false');
    dots[current].classList.add('is-active');
    dots[current].setAttribute('aria-selected', 'true');
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('next-btn')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>
