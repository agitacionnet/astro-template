---
// src/components/Hero.astro

export interface Props {
  name?: string;
  title?: string;
  subtitle?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  heroImage?: string;
  heroImageAlt?: string;
}

const {
  name         = 'Jane Cooper',
  title        = "Showcase Your Work with Airfolio's Creative Solutions",
  subtitle     = "Create stunning portfolios and websites with Airfolio's UI/UX design and Webflow development services.",
  ctaPrimary   = { label: 'Hire Me',   href: '/contact' },
  ctaSecondary = { label: 'Portfolio', href: '/portfolio' },
  heroImage    = '/images/hero-person.png',
  heroImageAlt = 'Jane Cooper — Portfolio designer',
} = Astro.props;
---

<section class="hero">

  <!-- Elementos decorativos flotantes -->
  <span class="hero__deco hero__deco--circle-tl" aria-hidden="true"></span>
  <span class="hero__deco hero__deco--shape-tr"  aria-hidden="true"></span>
  <span class="hero__deco hero__deco--arc-bl"    aria-hidden="true"></span>
  <span class="hero__deco hero__deco--dot-mr"    aria-hidden="true"></span>

  <div class="hero__inner">

    <!-- Columna izquierda: texto + CTAs -->
    <div class="hero__content">
      <p class="hero__greeting">Hi there, My name is {name}</p>
      <h1 class="hero__title">{title}</h1>
      <p class="hero__subtitle">{subtitle}</p>
      <div class="hero__actions">
        <a href={ctaPrimary.href}   class="btn-primary">{ctaPrimary.label}</a>
        <a href={ctaSecondary.href} class="btn-secondary">{ctaSecondary.label}</a>
      </div>
    </div>

    <!-- Columna derecha: imagen + blob de color -->
    <div class="hero__image-wrap">
      <div class="hero__blob" aria-hidden="true"></div>
      <img
        src={heroImage}
        alt={heroImageAlt}
        class="hero__image"
        width="385"
        height="582"
        loading="eager"
      />
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    background-color: var(--color-blue-3);
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--width-container);
    margin-inline: auto;
    padding-inline: var(--spacing-80);
    padding-top: 112px;
    display: flex;
    align-items: center;
    gap: var(--spacing-80);
  }

  /* ── Columna izquierda ─────────────────── */
  .hero__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-24);
  }

  .hero__greeting {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-black);
    margin: 0;
  }

  .hero__title {
    font-family: var(--font-sans);
    font-size: var(--font-size-6xl);   /* 56px */
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.82px;
    color: var(--color-black);
    margin: 0;
  }

  .hero__subtitle {
    font-family: var(--font-sans);
    font-size: var(--font-size-md);    /* 18px */
    font-weight: 400;
    line-height: 1.5;
    color: #3E3E70;
    margin: 0;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-16);
    padding-top: var(--spacing-16);
  }

  /* ── Columna derecha ───────────────────── */
  .hero__image-wrap {
    position: relative;
    flex-shrink: 0;
    width: 616px;
    height: 582px;
  }

  /* Blob de color (la mancha pintada del diseño) */
  .hero__blob {
    position: absolute;
    width: 110%;
    height: 85%;
    top: 5%;
    left: -5%;
    background: linear-gradient(
      135deg,
      #078D84 0%,
      #255BF9 50%,
      #7B3FE4 100%
    );
    border-radius: 60% 40% 50% 50% / 50% 50% 40% 60%;
    transform: rotate(-9deg);
    opacity: 0.9;
    z-index: 0;
  }

  .hero__image {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 100%;
    width: auto;
    object-fit: contain;
    object-position: bottom center;
    z-index: 1;
  }

  /* ── Decorativos ───────────────────────── */
  .hero__deco {
    position: absolute;
    pointer-events: none;
    z-index: 2;
  }

  .hero__deco--circle-tl {
    top: 58px;
    left: 27px;
    width: 30px;
    height: 30px;
    background-color: var(--color-blue-13);
    border-radius: 50%;
    opacity: 0.8;
  }

  .hero__deco--shape-tr {
    top: 61px;
    right: 80px;
    width: 22px;
    height: 28px;
    border: 2px solid var(--color-blue-13);
    border-radius: 3px;
    transform: rotate(32deg);
    opacity: 0.6;
  }

  .hero__deco--arc-bl {
    bottom: 40px;
    left: 48%;
    width: 62px;
    height: 44px;
    border: 2.5px solid var(--color-black);
    border-radius: 0 0 50px 50px;
    border-top: none;
    transform: rotate(56deg);
    opacity: 0.45;
  }

  .hero__deco--dot-mr {
    top: 102px;
    right: 200px;
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-black);
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    opacity: 0.4;
  }

  /* ── Responsive ────────────────────────── */
  @media (max-width: 1200px) {
    .hero__image-wrap {
      width: 460px;
      height: 440px;
    }
  }

  @media (max-width: 1024px) {
    .hero__inner {
      padding-inline: var(--spacing-40);
      gap: var(--spacing-40);
    }
    .hero__title {
      font-size: var(--font-size-4xl);
    }
    .hero__image-wrap {
      width: 380px;
      height: 380px;
    }
  }

  @media (max-width: 768px) {
    .hero__inner {
      flex-direction: column;
      padding-inline: var(--spacing-24);
      padding-top: var(--spacing-64);
      padding-bottom: var(--spacing-64);
      gap: var(--spacing-40);
    }
    .hero__title {
      font-size: var(--font-size-3xl);
    }
    .hero__image-wrap {
      width: 100%;
      height: 340px;
    }
    .hero__deco {
      display: none;
    }
  }
</style>
