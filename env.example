# ─── Strapi ────────────────────────────────────────────────────────────────────
# URL donde corre Strapi (local en desarrollo, dominio real en producción)
STRAPI_URL=http://localhost:1337

# API Token de Strapi (Settings → API Tokens → Create new token)
# Tipo: Read-only  |  Token type: Full access o personalizado con permisos de blog
STRAPI_TOKEN=tu_token_aqui

# ─── Astro (opcional) ──────────────────────────────────────────────────────────
# Descomenta si necesitas la URL pública del sitio (para sitemaps, OG, etc.)
# PUBLIC_SITE_URL=https://tudominio.com
